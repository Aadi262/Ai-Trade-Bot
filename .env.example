# ============================================================
# TradingBot-IN — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to git
# ============================================================

# ── Application ──────────────────────────────────────────────
SECRET_KEY=your-secret-key-min-32-chars
TRADING_MODE=paper                        # paper | live (live requires explicit sign-off)
PORT=8000
LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://tradingbot:password@postgres:5432/tradingbot
POSTGRES_USER=tradingbot
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=tradingbot

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Anthropic / Claude ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Zerodha Kite Connect (Phase 2 only) ──────────────────────
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=                        # Refreshed daily via login flow

# ── News & Data ───────────────────────────────────────────────
NEWSAPI_KEY=

# ── Monitoring & Alerts ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SENTRY_DSN=                               # Optional — leave blank to disable

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRES_IN=86400                      # 24 hours in seconds

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_SCAN_PER_MINUTE=10
RATE_LIMIT_SIGNAL_PER_MINUTE=60

# ── Port Overrides (change if another project is using defaults) ──
# Run: bash scripts/check_ports.sh  to auto-detect conflicts
API_PORT=8000
FLOWER_PORT=5555
REDIS_PORT=6379
POSTGRES_PORT=5432
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
